# Environment Variables

# Required for WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional: Custom RPC URL (defaults to public Base Sepolia RPC)
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Contract Address (already configured in code)
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x4c50dc3b966937e42f43ca0b4e334a0e72464409

# Base App ID (already configured in metadata)
# NEXT_PUBLIC_BASE_APP_ID=69c0b42b76e804b2a67a9f91

# Chain ID (already configured)
# NEXT_PUBLIC_CHAIN_ID=84532
